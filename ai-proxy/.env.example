PORT=8787

# Production should stay true.
AI_ENABLED=true

# Choose openai or groq.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# RevenueCat server-side verification.
# If this is true and REVENUECAT_SECRET_KEY is missing, AI calls are denied.
REQUIRE_REVENUECAT_PRO=true
REVENUECAT_SECRET_KEY=
REVENUECAT_ENTITLEMENT_ID=NO MORE BETS Pro

# Exact product IDs from RevenueCat/App Store Connect.
# Monthly Pro includes 50 base AI chats per calendar month.
# Annual Pro includes 100 base AI chats per calendar month.
# If the user has add-on credit left, add-on credit is used first.
# After add-on credit reaches 0, the current month's 100 base chats become available.
MONTHLY_PRODUCT_IDS=
ANNUAL_PRODUCT_IDS=
MUTUAL_PRODUCT_IDS=
# REQUIRED, and must list BOTH buyout SKUs. resolvePlan() matches these exactly (no substring
# fallback like the app has), so a missing or partial value makes every buyout customer resolve to
# an unknown plan — i.e. a monthly AI limit of 0 for someone who paid for "AI 无限，一辈子".
LIFETIME_PRODUCT_IDS=com.nomorebets.app.lifetime,com.nomorebets.app.lifetime_launch
MONTHLY_AI_LIMIT=50
ANNUAL_MONTHLY_AI_LIMIT=100

# AI add-on packs are usage credits, not monthly subscriptions.
# Example: the user pays $10, but the backend grants $3 of AI cost allowance.
# Unused add-on credit carries across months until it is fully used.
# Put the App Store/RevenueCat non-subscription product ID here.
AI_ADDON_10_PRODUCT_IDS=
AI_ADDON_10_CREDIT_CENTS=300

# Optional additional packs.
AI_ADDON_20_PRODUCT_IDS=
AI_ADDON_20_CREDIT_CENTS=600
AI_ADDON_50_PRODUCT_IDS=
AI_ADDON_50_CREDIT_CENTS=1500

# Alternative compact format:
# AI_ADDON_PACKS=product_id_1:300,product_id_2:600
AI_ADDON_PACKS=

# Hard total AI budget for the whole app, in cents.
# Example: 500 = $5/month. Start low until real usage is known.
GLOBAL_MONTHLY_BUDGET_CENTS=500

# Worst-case reserve per AI request, in cents.
# Annual base calls reserve only against the app global budget.
# Add-on calls also consume this amount from the user's carried add-on credits.
RESERVED_COST_PER_AI_CALL_CENTS=1

# Response size control.
MAX_OUTPUT_TOKENS=180
MAX_INPUT_CHARS=1800
MAX_MESSAGES=12

# Optional basic app gate. This is not a real secret once shipped in a mobile app,
# but it can reduce casual abuse of an open endpoint.
APP_PROXY_SHARED_SECRET=

USAGE_STORE_PATH=./data/usage-ledger.json

# Optional, required when invited users should share/sync AI quota through Supabase.
USE_SUPABASE_AI_GROUPS=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
