{
  "expo": {
    "name": "NO MORE BETS",
    "slug": "NoMoreBets",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nomorebets",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nomorebets.app",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "用于拍摄账号头像或重要联系人头像，帮助你在冲动时看到支持你的人。",
        "NSPhotoLibraryUsageDescription": "用于选择账号头像或重要联系人头像，帮助你在冲动时看到支持你的人。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2E7D32",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.nomorebets.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAF7",
          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "58f0dd56-30e8-4429-8b29-75835edca82f"
      }
    }
  }
}
